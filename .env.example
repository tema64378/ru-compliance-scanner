# Скопируй в .env и заполни. На хостинге задай эти же переменные в настройках сервиса.

# Telegram-бот (токен от @BotFather)
BOT_TOKEN=

# Робокасса (из личного кабинета магазина)
ROBOKASSA_LOGIN=
ROBOKASSA_PASS1=
ROBOKASSA_PASS2=
ROBOKASSA_TEST=1

# E-mail для отправки документов после оплаты
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
